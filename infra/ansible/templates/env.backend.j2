# ── Entorno ──────────────────────────────────────────────────────────────────
# Generado por Ansible — NO EDITAR MANUALMENTE
DEPLOYMENT_ENV={{ backend_deployment_env }}
DEBUG=false

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="SCADA Backend (NAS)"
API_V1_PREFIX={{ backend_api_prefix }}

# ── PostgreSQL / TimescaleDB ──────────────────────────────────────────────────
# Nota: POSTGRES_HOST se inyecta como env var en docker-compose (=timescaledb)
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB={{ postgres_db }}

# ── MQTT — Loopback interno sin TLS (red Docker) ─────────────────────────────
# Nota: MQTT_BROKER_HOST se inyecta como env var en docker-compose (=mosquitto)
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID={{ mqtt_client_id }}
MQTT_USERNAME={{ mqtt_health_user }}
MQTT_PASSWORD={{ vault_mqtt_health_pass }}
MQTT_USE_TLS=false
MQTT_KEEPALIVE=60
MQTT_RECONNECT_DELAY=5.0

# ── Seguridad (JWT) ───────────────────────────────────────────────────────────
SECRET_KEY={{ vault_jwt_secret_key }}
ALGORITHM={{ jwt_algorithm }}
ACCESS_TOKEN_EXPIRE_MINUTES={{ jwt_expire_minutes }}

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS={{ backend_cors_origins }}
