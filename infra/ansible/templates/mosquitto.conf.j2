# =============================================================
# Mosquitto SCADA — Configuración NAS Producción
# Generado por Ansible — NO EDITAR MANUALMENTE
# =============================================================
# Arquitectura: Eclipse Mosquitto 2.x en Docker
# Rutas internas del contenedor:
#   Certs:  /mosquitto/certs/
#   Config: /mosquitto/config/
#   Data:   /mosquitto/data/
# =============================================================

# -------------------------------------------------------------
# Global
# -------------------------------------------------------------
persistence true
persistence_location /mosquitto/data/
log_dest stdout
connection_messages true

# =============================================================
# LISTENER 1 — MQTT TCP (Puerto 1883)
# Propósito: Comunicación interna contenedor-a-contenedor.
#            El backend FastAPI se conecta por aquí.
# Seguridad: Restringido a la red Docker interna.
#            Autenticación por usuario/contraseña.
# =============================================================
listener 1883
protocol mqtt
allow_anonymous false
password_file /mosquitto/config/passwd

# =============================================================
# LISTENER 2 — WebSockets en texto plano (Puerto 8883)
# Propósito: Conexiones del Frontend React/Next.js (HMI).
#            El navegador usa WS (WebSocket) para
#            suscribirse a los tópicos en tiempo real.
# Seguridad: Autenticación por usuario/contraseña.
#            Sin TLS (red local confiable).
# =============================================================
listener 8883
protocol websockets
allow_anonymous false
password_file /mosquitto/config/passwd

# =============================================================
# LISTENER 3 — MQTTS con mTLS (Puerto 8884)
# Propósito: Conexiones de nodos Edge físicos en campo.
#            Cada dispositivo debe presentar un certificado
#            cliente firmado por la CA privada (SCADA Root CA).
# Seguridad: Autenticación mutua (mTLS). El CN del cert
#            actúa como username (use_identity_as_username).
# =============================================================
listener 8884
protocol mqtt
cafile   /mosquitto/certs/ca.crt
certfile /mosquitto/certs/server.crt
keyfile  /mosquitto/certs/server.key
tls_version tlsv1.2
require_certificate true
use_identity_as_username true
allow_anonymous false
